SECRET_KEY=change-this-secret-key-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
# SQLite (para desarrollo local)
DATABASE_URL=sqlite:///./artizan.db
# PostgreSQL (descomentar y configurar para producción)
# DATABASE_URL=postgresql://usuario:contraseña@localhost:5432/artizan_db
UPLOAD_DIR=uploads
MAX_IMAGE_SIZE_MB=10
# Comma-separated list of allowed origins. Use * to allow all (not recommended in production).
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
